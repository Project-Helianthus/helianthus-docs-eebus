{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:eebus:api-surface:v1",
  "schema_id": "helianthus.eebus.api-surface.v1",
  "schema_version": 1,
  "title": "Helianthus eeBUS Go API surface v1",
  "description": "Closed, deterministic representation of an eeBUS Go public API surface.",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "packages"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "helianthus.eebus.api-surface.v1"
    },
    "schema_version": {
      "const": 1
    },
    "fixture": {
      "$ref": "#/$defs/fixture"
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "required": [
        "synthetic",
        "runtime_claims"
      ],
      "additionalProperties": false,
      "properties": {
        "synthetic": {
          "const": true
        },
        "runtime_claims": {
          "const": false
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "path",
        "name",
        "symbols"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/symbol"
          }
        }
      }
    },
    "symbol": {
      "type": "object",
      "required": [
        "kind",
        "name",
        "type",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "const",
            "func",
            "method",
            "type",
            "var"
          ]
        },
        "receiver": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "method"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "receiver"
            ]
          },
          "else": {
            "not": {
              "required": [
                "receiver"
              ]
            }
          }
        }
      ]
    }
  }
}
