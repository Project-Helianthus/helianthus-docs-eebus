{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:eebus:api-surface:v1",
  "schema_id": "helianthus.eebus.api-surface.v1",
  "schema_version": 1,
  "title": "Helianthus eeBUS Go API surface v1",
  "description": "Closed deterministic representation and corpus contract for a future AST-produced eeBUS Go public API surface; this schema does not prove Go semantics.",
  "$comment": "Before emission, an AST-backed producer must prove Go syntax, canonical spelling, and semantic consistency. Consumers may rely only on the representation and corpus invariants declared here.",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "packages"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "helianthus.eebus.api-surface.v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "fixture": {
      "$ref": "#/$defs/fixture"
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "asciiGoIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "not": {
        "enum": [
          "break",
          "case",
          "chan",
          "const",
          "continue",
          "default",
          "defer",
          "else",
          "fallthrough",
          "for",
          "func",
          "go",
          "goto",
          "if",
          "import",
          "interface",
          "map",
          "package",
          "range",
          "return",
          "select",
          "struct",
          "switch",
          "type",
          "var"
        ]
      }
    },
    "exportedAsciiGoIdentifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9_]*$"
    },
    "fixture": {
      "type": "object",
      "required": [
        "synthetic",
        "runtime_claims"
      ],
      "additionalProperties": false,
      "properties": {
        "synthetic": {
          "const": true
        },
        "runtime_claims": {
          "const": false
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "path",
        "name",
        "symbols"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "$ref": "#/$defs/asciiGoIdentifier"
        },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/symbol"
          }
        }
      }
    },
    "symbol": {
      "type": "object",
      "required": [
        "kind",
        "name",
        "type",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "const",
            "func",
            "method",
            "type",
            "var"
          ]
        },
        "receiver": {
          "type": "string",
          "pattern": "^\\*?[A-Za-z_][A-Za-z0-9_]*(?:\\[[A-Za-z_][A-Za-z0-9_]*(?:, [A-Za-z_][A-Za-z0-9_]*)*\\])?$"
        },
        "name": {
          "$ref": "#/$defs/exportedAsciiGoIdentifier"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "method"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "receiver"
            ]
          },
          "else": {
            "not": {
              "required": [
                "receiver"
              ]
            }
          }
        }
      ]
    }
  }
}
