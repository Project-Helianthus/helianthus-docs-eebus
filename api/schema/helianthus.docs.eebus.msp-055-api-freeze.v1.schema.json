      "required": ["reference", "landing", "stable_channels"],
      "properties": {
        "reference": {"const": "api/eebusruntime-v1/reference.md"},
        "landing": {"const": "api/README.md"},
        "stable_channels": {
          "type": "array",
          "prefixItems": [
            {"const": "api/search-index.json"},
            {"const": "api/sitemap.xml"},
            {"const": "api/versioned-bundle.txt"},
            {"const": "api/release-bundle.txt"}
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        }
      }
