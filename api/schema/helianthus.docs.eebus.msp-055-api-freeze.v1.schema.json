    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "predicate", "attestation", "verification"],
      "properties": {
        "manifest": {"$ref": "#/$defs/artifact"},
        "predicate": {"$ref": "#/$defs/artifact"},
        "attestation": {"$ref": "#/$defs/artifact"},
        "verification": {"$ref": "#/$defs/artifact"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "pull_request", "commit", "tree", "ref", "merged_at"],
      "properties": {
        "repository": {"const": "Project-Helianthus/helianthus-eebusreg"},
        "pull_request": {"type": "integer", "const": 45},
        "commit": {"const": "6af4cdcedb5f7f93d01a53c48c6abc0c19f92edb"},
        "tree": {"const": "b090651c99d5b6817a40997b14c1b6a2a37c124e"},
        "ref": {"const": "refs/heads/issue/44-pre-release-api-v1"},
