{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:eebus:msp-055-api-freeze:v1",
  "schema_id": "helianthus.docs.eebus.msp-055-api-freeze.v1",
  "schema_version": 1,
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "state",
    "version",
    "source",
    "candidate",
    "run",
    "attestation",
    "artifacts",
    "publication",
    "verification_policy",
    "invalidation_conditions"
  ],
  "properties": {
    "schema_id": {"const": "helianthus.docs.eebus.msp-055-api-freeze.v1"},
    "schema_version": {"type": "integer", "const": 1},
    "state": {"const": "active"},
    "version": {"const": "eebusruntime-v1"},
    "source": {"$ref": "#/$defs/source"},
    "candidate": {"$ref": "#/$defs/candidate"},
    "run": {"$ref": "#/$defs/run"},
    "attestation": {"$ref": "#/$defs/attestation"},
    "artifacts": {"$ref": "#/$defs/artifacts"},
    "publication": {"$ref": "#/$defs/publication"},
    "verification_policy": {"$ref": "#/$defs/verification_policy"},
    "invalidation_conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
