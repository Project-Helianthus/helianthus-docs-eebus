        "docs_commit": {"const": "df231977989625fae8a92d94b3ca88ef9e52c6f2"},
        "docs_merged_at": {"const": "2026-07-15T09:43:13Z"},
        "source_commit": {"const": "ad79f0bbe589d95d56cc738203604fec78639d90"},
        "source_tree": {"const": "01c17785fe9aac8d8536545e03e1ec1d4a4dff9d"},
        "source_ref": {"const": "refs/heads/issue/24-msp055-lifecycle-facade"},
        "record_path": {"const": "api/_candidate/msp-055/candidate-record.json"},
        "reference_path": {"const": "api/_candidate/runtime-reference.md"},
        "state": {"const": "retired"},
        "artifacts": {"$ref": "#/$defs/artifacts"}
