    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "attempt", "event", "conclusion", "ref", "artifact_id", "artifact_name"],
      "properties": {
        "id": {"type": "integer", "const": 29638678140},
        "attempt": {"type": "integer", "const": 1},
        "event": {"const": "pull_request"},
        "conclusion": {"const": "success"},
        "ref": {"const": "refs/heads/issue/44-pre-release-api-v1"},
        "artifact_id": {"type": "integer", "const": 8427914108},
        "artifact_name": {"const": "helianthus-eebusreg-api-surface-v1-29638678140-1"}
